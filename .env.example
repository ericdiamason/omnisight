# ═══════════════════════════════════════════════════════════════════
# OmniSight — Environment Variables Template
# ═══════════════════════════════════════════════════════════════════
# 1. Copy this file:   cp .env.example .env
# 2. Fill in values:   nano .env
# 3. NEVER commit .env to git — it is in .gitignore
#
# On OCI production: set these as environment variables in your
# systemd unit or OCI Vault secret references.
# ═══════════════════════════════════════════════════════════════════

# ── PostgreSQL ─────────────────────────────────────────────────────
POSTGRES_DB=postgres
POSTGRES_USER=omnisight_user
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# ── Airflow ────────────────────────────────────────────────────────
# Generate Fernet key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=CHANGE_ME_fernet_key_here
AIRFLOW_SECRET_KEY=CHANGE_ME_webserver_secret_key_here

# ── Blockchain node (Alchemy / Infura / QuickNode) ─────────────────
# Never use an unauthenticated public endpoint in production
OMNISIGHT_NODE_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_API_KEY_HERE

# ── Slack alerting (optional but strongly recommended) ─────────────
# Create at: https://api.slack.com/apps → Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ── API ────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://omnisight_user:CHANGE_ME_strong_password_here@postgres:5432/postgres

# ── OCI (if using OCI Vault for secret rotation) ───────────────────
# OCI_VAULT_SECRET_ID=ocid1.vaultsecret.oc1...
